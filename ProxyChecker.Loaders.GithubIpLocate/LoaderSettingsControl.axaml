<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ProxyChecker.Loaders.GithubIpLocate"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:LoaderSettingsControlViewModel"
             x:Class="ProxyChecker.Loaders.GithubIpLocate.LoaderSettingsControl">
	<Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto">
		<TextBlock Grid.Column="0" Grid.Row="0" Classes="form-label" Text="{x:Static vm:Resource.ProtocolLabel}" />
		<ComboBox  Grid.Column="1" Grid.Row="0" Classes="m5" HorizontalAlignment="Stretch"
			ItemsSource="{Binding Protocols}"
			SelectedValue="{Binding Protocol}"
			SelectedValueBinding="{Binding Code, DataType={x:Type vm:CodeWithName}}"
			DisplayMemberBinding="{Binding Name, DataType={x:Type vm:CodeWithName}}">
		</ComboBox>
		<TextBlock Grid.Column="0" Grid.Row="1" Classes="form-label" Text="{x:Static vm:Resource.CountryLabel}" />
		<ComboBox  Grid.Column="1" Grid.Row="1" Classes="m5" HorizontalAlignment="Stretch"
			ItemsSource="{Binding Countries}"
			SelectedValue="{Binding Country}"
			SelectedValueBinding="{Binding Code, DataType={x:Type vm:CodeWithName}}"
			DisplayMemberBinding="{Binding Name, DataType={x:Type vm:CodeWithName}}">
		</ComboBox>
		<TextBlock Grid.Column="0" Grid.Row="2" Classes="form-label" Text="{x:Static vm:Resource.ProxyUriLabel}" />
		<TextBox Grid.Column="1" Grid.Row="2" Classes="m5" Text="{Binding ProxyUriString}" />
		<TextBlock Grid.Column="0" Grid.Row="3" Classes="form-label" Text="{x:Static vm:Resource.TimeoutLabel}" />
		<NumericUpDown Grid.Column="1" Grid.Row="3" Classes="m5" Value="{Binding TimeoutInSeconds}"
			ParsingNumberStyle="Integer" FormatString="N0" ShowButtonSpinner="False"/>
	</Grid>
</UserControl>
