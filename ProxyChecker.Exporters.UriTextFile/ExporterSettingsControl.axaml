<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ProxyChecker.Exporters.UriTextFile"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:ExporterSettingsControlViewModel"
             x:Class="ProxyChecker.Exporters.UriTextFile.ExporterSettingsControl">
	<DockPanel>
		<Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto" ColumnSpacing="10">
			<TextBlock Grid.Column="0" Classes="form-label" Text="{x:Static vm:Resource.FilePathLabel}" />
			<TextBox Grid.Column="1" Text="{Binding FilePath}" Margin="0,5,0,5"></TextBox>
			<Button  Grid.Column="2" Command="{Binding SelectFilePathCommand}" Classes="action-button" Content="{x:Static vm:Resource.SelectButtonText}"/>
		</Grid>
	</DockPanel>
</UserControl>
