<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ProxyChecker.ViewModels"
        xmlns:asts="using:ProxyChecker.Interfaces.Resources"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ProxyChecker.LoadersWindow"
        x:DataType="vm:LoadersWindowViewModel"
        Width="700" Height="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Icon="/Assets/proxy-checker.ico"
        Title="{x:Static asts:Resource.LoadersWindowTitle}">
  <DockPanel LastChildFill="True">
    <StackPanel Classes="buttons-panel" DockPanel.Dock="Top" HorizontalAlignment="Center" Orientation="Horizontal" Margin="5">
      <Button Classes="action-button" Command="{Binding AddCommand}" Content="{x:Static asts:Resource.AddButtonText}"/>
    </StackPanel>
    <ItemsControl ItemsSource="{Binding Loaders}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Margin="5,10,5,5"
									CornerRadius="5"
									BorderBrush="Gray" BorderThickness="1"
									Padding="5">
            <DockPanel>
              <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="10,0,0,0" />
              <StackPanel Classes="buttons-panel" DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
								<Button
									Classes="action-button"
									Command="{Binding $parent[Window].((vm:LoadersWindowViewModel)DataContext).MakeActiveCommand}"
									CommandParameter="{Binding}"
                  Content="{x:Static asts:Resource.MakeActiveButtonText}"
                  IsVisible="{Binding !IsActive}"/>
								<Button
									Classes="action-button"
									Command="{Binding $parent[Window].((vm:LoadersWindowViewModel)DataContext).ShowSettingsCommand}"
									CommandParameter="{Binding}"
                  Content="{x:Static asts:Resource.SettingsButtonText}"/>
                <Button
                  Classes="action-button"
									Command="{Binding $parent[Window].((vm:LoadersWindowViewModel)DataContext).DeleteCommand}"
									CommandParameter="{Binding}"
                  Content="{x:Static asts:Resource.DeleteButtonText}"/>
              </StackPanel>
            </DockPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </DockPanel>
</Window>
