<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ProxyChecker.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ProxyChecker.LoaderSettingsWindow"
        x:DataType="vm:LoaderSettingsWindowViewModel"
        Title="LoaderSettingsWindow">
	<DockPanel LastChildFill="True">
		<Grid DockPanel.Dock="Top" ColumnDefinitions="Auto, *">
			<TextBlock Grid.Column="0" Text="Name" />
			<TextBox Grid.Column="1" Text="{Binding Name}" MaxLength="256"/>
		</Grid>
		<StackPanel DockPanel.Dock="Bottom" Classes="buttons-panel" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Classes="action-button" Command="{Binding OkCommand}">Ok</Button>
      <Button Classes="action-button" Command="{Binding CancelCommand}">Cancel</Button>
		</StackPanel>
    <ScrollViewer>
      <ContentControl Content="{Binding SettingsControl}"/>
		</ScrollViewer>
	</DockPanel>

</Window>
