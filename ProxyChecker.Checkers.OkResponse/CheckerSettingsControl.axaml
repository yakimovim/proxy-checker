<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ProxyChecker.Checkers.OkResponse"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:CheckerSettingsControlViewModel"
             x:Class="ProxyChecker.Checkers.OkResponse.CheckerSettingsControl">
	<DockPanel LastChildFill="True" Margin="5">
		<Grid DockPanel.Dock="Top" ColumnDefinitions="Auto, *, Auto">
			<TextBlock Grid.Column="0" Classes="form-label" Text="Target URI" />
			<TextBox Grid.Column="1" Classes="m5" Text="{Binding TargetUriCandidate}"/>
			<Button Grid.Column="2" Classes="action-button" Command="{Binding AddTargetUriCommand}">Add</Button>
    </Grid>
		<Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto, *">
			<TextBlock Grid.Column="0" Classes="form-label" Text="Timeout (seconds)" />
			<NumericUpDown Grid.Column="1" Classes="m5" Value="{Binding TimeoutInSeconds}"
				Minimum="1" Maximum="600"
				ParsingNumberStyle="Integer" FormatString="N0" ShowButtonSpinner="False"/>
		</Grid>		<ScrollViewer>
			<ItemsControl ItemsSource="{Binding TargetUris}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Margin="0,10,0,0"
										CornerRadius="5"
										BorderBrush="Gray" BorderThickness="1"
										Padding="5">
							<StackPanel Orientation="Horizontal">
								<TextBlock Margin="5 0" FontWeight="Bold" Text="{Binding}" />
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</DockPanel>
</UserControl>
