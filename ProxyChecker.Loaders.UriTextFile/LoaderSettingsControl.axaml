<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ProxyChecker.Loaders.UriTextFile"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:LoaderSettingsControlViewModel"
             x:Class="ProxyChecker.Loaders.UriTextFile.LoaderSettingsControl">
	<DockPanel>
		<Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto" ColumnSpacing="10">
			<TextBlock Grid.Column="0">File path</TextBlock>
			<TextBox Grid.Column="1" Text="{Binding FilePath}"></TextBox>
      <Button  Grid.Column="2" Command="{Binding SelectFilePathCommand}">Select</Button>
		</Grid>
	</DockPanel>
</UserControl>
