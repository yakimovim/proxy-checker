<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ProxyChecker.Loaders.UriTextFile"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:DataType="vm:LoaderSettingsWindowViewModel"
        x:Class="ProxyChecker.Loaders.UriTextFile.LoaderSettingsWindow"
        Title="LoaderSettingsWindow">
  <DockPanel LastChildFill="True">
    <StackPanel DockPanel.Dock="Bottom" Classes="buttons-panel" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Classes="action-button" Command="{Binding OkCommand}">Ok</Button>
      <Button Classes="action-button" Command="{Binding CancelCommand}">Cancel</Button>
    </StackPanel>
    <ScrollViewer>
      <ContentControl Content="{Binding SettingsControl}"/>
    </ScrollViewer>
  </DockPanel>
</Window>
