<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ProxyChecker.Interfaces.ViewModels"
        xmlns:asts="using:ProxyChecker.Interfaces.Resources"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ProxyChecker.Interfaces.PluginSettingsWindow"
        x:DataType="vm:PluginSettingsWindowViewModel"
        Width="700" Height="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Icon="/Resources/proxy-checker.ico"
        Title="">
	<DockPanel LastChildFill="True">
		<StackPanel DockPanel.Dock="Bottom" Classes="buttons-panel" Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Classes="action-button" Command="{Binding OkCommand}" Content="{x:Static asts:Resource.OkButtonText}"/>
			<Button Classes="action-button" Command="{Binding CancelCommand}" Content="{x:Static asts:Resource.CancelButtonText}"/>
		</StackPanel>
		<ScrollViewer>
			<ContentControl Content="{Binding SettingsControl}"/>
		</ScrollViewer>
	</DockPanel>
</Window>
