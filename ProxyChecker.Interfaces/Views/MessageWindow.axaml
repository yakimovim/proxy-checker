<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ProxyChecker.Interfaces.ViewModels"
        xmlns:asts="using:ProxyChecker.Interfaces.Resources"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ProxyChecker.Interfaces.MessageWindow"
        x:DataType="vm:MessageWindowViewModel"
        Width="500" Height="300"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Icon="/Resources/proxy-checker.ico"
        Title="{x:Static asts:Resource.MessageWindowTitle}">
	<DockPanel LastChildFill="True" Margin="5">
		<StackPanel DockPanel.Dock="Bottom" Classes="buttons-panel" Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Classes="action-button" Command="{Binding OkCommand}" Content="{x:Static asts:Resource.OkButtonText}"/>
		</StackPanel>
		<TextBlock TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center"
			Margin="5"
			Text="{Binding Message}" />
	</DockPanel>
</Window>
